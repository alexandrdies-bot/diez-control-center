# API

API_HOST=127.0.0.1
API_PORT=3001

# Production CORS allowlist. Comma-separated origins.
# In local development broad CORS is allowed when NODE_ENV is not production.
CORS_ALLOWED_ORIGINS=https://example.ru,https://www.example.ru

# MVP API protection for production write/admin endpoints.
# Use real secret values only in local/server .env, never in git.
API_WRITE_KEY=change-me
ADMIN_API_KEY=change-me-admin

# Desktop client API config. Use real keys only in local/server env.
VITE_API_BASE_URL=http://127.0.0.1:3001
VITE_API_WRITE_KEY=
VITE_ADMIN_API_KEY=

# Database

# Реальный DATABASE_URL хранить только в локальном .env.

# Desktop-клиент не должен хранить пароль PostgreSQL.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Optional. Only for local debug calculation endpoints.
# CONSTRUCTOR_FIXTURES_DIR=D:/_ProjectHome/diez-site/outputs/constructor-fixtures

