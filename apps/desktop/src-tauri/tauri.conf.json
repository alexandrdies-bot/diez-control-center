{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Диез Имидж Control Center",
  "version": "0.0.0",
  "identifier": "ru.diezimage.controlcenter",
  "build": {
    "beforeDevCommand": "pnpm dev --host 127.0.0.1",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Диез Имидж Control Center",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
